  "keyFeatures": [
    "JWT-based authentication with role-based access control",
    "Product catalog management with categories and image uploads",
    "Shopping cart functionality with persistent storage",
    "Order creation and management system",
    "Rate limiting and security middleware",
    "Prisma ORM with MySQL database",
    "Docker containerization with docker-compose"
  ],
  "publicApiSurface": [
    "POST /auth/register - Register a new customer account",
    "POST /auth/login - Authenticate and receive JWT token",
    "PUT /auth/profile - Update user profile (authenticated)",
    "DELETE /auth/delete - Delete user account (authenticated)",
    "POST /auth/create-user - Create user with specific role (admin only)",
    "GET /products - List all products (public)",
    "GET /products/:id - Get product by ID (public)",
    "POST /products - Create product with image (admin only)",
    "PUT /products/:id - Update product (admin only)",
    "DELETE /products/:id - Delete product (admin only)",
    "GET /categories - List all categories (public)",
    "POST /categories - Create category (admin only)",
    "PUT /categories/:id - Update category (admin only)",
    "DELETE /categories/:id - Delete category (admin only)",
    "GET /cart - Get user's cart (authenticated)",
    "POST /cart/add - Add item to cart (authenticated)",
    "PUT /cart/item/:id - Update cart item quantity (authenticated)",
    "DELETE /cart/item/:id - Remove item from cart (authenticated)",
    "DELETE /cart/clear - Clear entire cart (authenticated)",
    "POST /orders - Create order from cart (authenticated)",
    "GET /orders - List user's orders (authenticated)",
    "GET /orders/:id - Get order details (authenticated)"
  ]
}
